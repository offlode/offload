# ============================================================
# Offload — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Application ──
NODE_ENV=production
PORT=5000
APP_VERSION=1.0.0

# ── Database ──
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/offload_prod
# For development/pilot, SQLite is used by default (no config needed)

# ── Stripe Payments ──
# Required for real payment processing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SendGrid Email ──
# Required for email notifications
SENDGRID_API_KEY=SG....

# ── Photo Storage (Cloudflare R2) ──
# Canonical names used by the app:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=offload-photos
# Optional explicit endpoint, otherwise derived from R2_ACCOUNT_ID:
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Legacy aliases still accepted: R2_API_TOKEN, R2_BUCKET, R2_ENDPOINT

# ── Error Tracking ──
# SENTRY_DSN=https://...@sentry.io/...

# ── Feature Flags ──
# ENFORCE_PHOTOS=true           # Require photo proof at handoff points
# ENFORCE_WEIGHT_CHECK=true     # Require weight verification

# ── Security ──
# SESSION_SECRET=change-this-to-a-random-string
# CORS_ALLOWED_ORIGINS=https://offloadusa.com,https://app.offloadusa.com

# ── Domain ──
# DOMAIN=offloadusa.com
# APP_URL=https://app.offloadusa.com
# SITE_URL=https://offloadusa.com

# ── SMS (Twilio) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Push Notifications (APNs) ──
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.offloadusa.app
APNS_KEY_PATH=

# ── Google Maps / Places ──
GOOGLE_MAPS_API_KEY=
